###############################################
# 3. PAGINATED CUSTOMERS
###############################################

### Get all customers (default pagination)
GET {{baseUrl}}/customers/

### Expected: First page with 10 customers (default)
# Response includes pagination metadata

### Get first page with 5 customers per page
GET {{baseUrl}}/customers/?page=1&per_page=5

### Get second page with 5 customers per page
GET {{baseUrl}}/customers/?page=2&per_page=5

### Get page 1 with 20 customers per page
GET {{baseUrl}}/customers/?page=1&per_page=20

### Test with invalid page number (should default to 1)
GET {{baseUrl}}/customers/?page=0

### Test with excessive per_page (should cap at 100)
GET {{baseUrl}}/customers/?page=1&per_page=500

### Test last page
GET {{baseUrl}}/customers/?page=10&per_page=10

