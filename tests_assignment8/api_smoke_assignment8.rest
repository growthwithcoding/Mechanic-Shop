# 1. EDIT SERVICE TICKET MECHANICS
###############################################

### Add mechanics to a ticket
PUT {{baseUrl}}/service-tickets/1/edit
Content-Type: application/json

{
  "add_ids": [1, 2, 3]
}

### Remove mechanics from a ticket
PUT {{baseUrl}}/service-tickets/1/edit
Content-Type: application/json

{
  "remove_ids": [2]
}

### Bulk add and remove mechanics
PUT {{baseUrl}}/service-tickets/1/edit
Content-Type: application/json

{
  "add_ids": [4, 5],
  "remove_ids": [3]
}

### Test with non-existent ticket
PUT {{baseUrl}}/service-tickets/9999/edit
Content-Type: application/json

{
  "add_ids": [1]
}

