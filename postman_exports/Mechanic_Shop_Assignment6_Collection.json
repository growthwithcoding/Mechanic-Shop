        {
          "name": "POST /service-tickets - Requests 1-10 (Bulk Test)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_name\": \"John Doe {{$randomInt}}\",\n  \"customer_email\": \"john{{$randomInt}}@example.com\",\n  \"customer_phone\": \"555-1234\",\n  \"vehicle_make\": \"Toyota\",\n  \"vehicle_model\": \"Camry\",\n  \"vehicle_year\": 2020,\n  \"description\": \"Oil change needed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/service-tickets/",
              "host": ["{{base_url}}"],
              "path": ["service-tickets", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// This test should be run 10 times using Collection Runner",
                  "var iteration = pm.info.iteration + 1;",
                  "",
                  "if (iteration <= 10) {",
                  "    pm.test('Request ' + iteration + ': Status code is 201 (within rate limit)', function () {",
                  "        pm.response.to.have.status(201);",
                  "    });",
                  "} else {",
                  "    pm.test('Request ' + iteration + ': Status code is 429 (rate limit exceeded)', function () {",
                  "        pm.response.to.have.status(429);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
