    {
      "name": "2. Caching Tests",
      "description": "Tests to verify caching functionality on GET endpoints",
      "item": [
        {
          "name": "GET /mechanics (First Request - Cache Miss)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/mechanics/",
              "host": ["{{base_url}}"],
              "path": ["mechanics", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});",
                  "",
                  "// Store response time for comparison",
                  "pm.collectionVariables.set('first_response_time', pm.response.responseTime);",
                  "console.log('First request response time (cache miss):', pm.response.responseTime, 'ms');"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /mechanics (Second Request - Cache Hit)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/mechanics/",
              "host": ["{{base_url}}"],
              "path": ["mechanics", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Compare with first request",
                  "var firstTime = pm.collectionVariables.get('first_response_time');",
                  "var currentTime = pm.response.responseTime;",
                  "console.log('Second request response time (cache hit):', currentTime, 'ms');",
                  "console.log('First vs Second:', firstTime, 'ms vs', currentTime, 'ms');",
                  "",
                  "pm.test('Cached response should be faster or similar', function () {",
                  "    // Cached responses are typically faster but not always guaranteed",
                  "    pm.expect(currentTime).to.be.below(firstTime * 2);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /mechanics (Third Request - Still Cached)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/mechanics/",
              "host": ["{{base_url}}"],
              "path": ["mechanics", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "console.log('Third request response time (still cached):', pm.response.responseTime, 'ms');",
                  "",
                  "pm.test('Response is consistent', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
