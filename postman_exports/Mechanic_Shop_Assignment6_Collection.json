{
  "info": {
    "_postman_id": "mechanic-shop-api-assignment-6",
    "name": "Mechanic Shop API - Assignment 6 (Rate Limiting & Caching)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Tests for Assignment 6: Rate Limiting and Caching features.\n\nThis collection tests:\n- Rate limiting on POST endpoints\n- Caching on GET endpoints\n- Proper 429 responses when limits are exceeded\n- Cache behavior with timing tests\n\n**Important:** Run tests sequentially, not in parallel. Some tests require waiting periods."
  },
  "item": [
    {
      "name": "1. Rate Limiting Tests",
      "description": "Tests to verify rate limiting functionality on POST endpoints",
      "item": [
        {
          "name": "POST /mechanics - Request 1 of 6",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Mechanic 1\",\n  \"email\": \"test1@example.com\",\n  \"phone\": \"555-0001\",\n  \"salary\": 50000\n}"
            },
            "url": {
              "raw": "{{base_url}}/mechanics/",
              "host": ["{{base_url}}"],
              "path": ["mechanics", ""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 (within rate limit)', function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
