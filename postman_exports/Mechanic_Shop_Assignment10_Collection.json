{
	"info": {
		"_postman_id": "assignment10-inventory-collection",
		"name": "Mechanic Shop API - Assignment 10 (Inventory)",
		"description": "Complete API collection for Assignment 10 - Inventory Management System\n\nThis collection includes:\n- Full CRUD operations for Inventory management\n- Service Ticket and Inventory integration\n- All previous assignment features (Authentication, Rate Limiting, Caching, etc.)\n\nNew Endpoints:\n- POST /inventory/ - Create inventory part\n- GET /inventory/ - List all inventory\n- GET /inventory/<id> - Get single part\n- PUT /inventory/<id> - Update part\n- DELETE /inventory/<id> - Delete part\n- POST /service-tickets/<ticket_id>/add-part/<inventory_id> - Add part to ticket",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
